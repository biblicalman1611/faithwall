# Environment Variables for FaithWall
# Copy this to .env.local for local dev, or set in Vercel dashboard for production

# Resend API Key — for sending welcome emails
# Get yours at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Stripe keys are hardcoded in src/config/stripe.ts (publishable key only, safe for frontend)
